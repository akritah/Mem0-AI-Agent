# ── VoiceAgent Environment Variables ────────────────────────────────────────

# Ollama settings (default: localhost)
OLLAMA_URL=http://localhost:11434

# Default local model used by tool execution.
# Must match a model in `ollama list` (example: llama3.2, mistral, codellama)
OLLAMA_MODEL=llama3.2

# Ollama request timeout/retry settings (increase if model responses are slow)
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_MAX_RETRIES=2

# Whisper model size: tiny | base | small | medium | large-v3
# Smaller = faster but less accurate. 'base' is a good starting point.
WHISPER_MODEL_SIZE=base

# (Optional) Groq API Key - use if your machine can't run Whisper locally
# Get one free at https://console.groq.com
# GROQ_API_KEY=your_groq_api_key_here

# Mem0 cloud memory key (optional, enables cross-session preference memory)
MEM0_API_KEY=your_mem0_api_key_here
